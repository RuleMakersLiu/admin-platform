# Admin Python Backend 配置

# 服务配置
APP_NAME=Admin Platform
APP_VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8081

# 数据库配置
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/admin_platform

# Redis配置
REDIS_URL=redis://localhost:6379/0

# JWT配置
# SECURITY: 使用 openssl rand -hex 32 生成
JWT_SECRET=CHANGE-ME-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Claude API配置
CLAUDE_API_KEY=your-api-key-here
CLAUDE_DEFAULT_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096

# CORS配置
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ==================== 多渠道消息配置 ====================

# Telegram Bot 配置
# 从 @BotFather 获取
TELEGRAM_BOT_TOKEN=
# Webhook 验证 token（可选，在 BotFather 中设置）
TELEGRAM_SECRET_TOKEN=

# Discord Bot 配置
# 从 Discord Developer Portal 获取
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
# 用于验证 Interaction 签名
DISCORD_PUBLIC_KEY=

# Slack Bot 配置
# 从 Slack App 管理页面获取
SLACK_BOT_TOKEN=xoxb-xxx
SLACK_APP_TOKEN=xapp-xxx
# 从 Basic Information 页面获取
SLACK_SIGNING_SECRET=

# 飞书 Bot 配置
# 从飞书开放平台获取
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 消息加密密钥（可选）
FEISHU_ENCRYPT_KEY=
# Webhook 验证 token
FEISHU_VERIFICATION_TOKEN=
